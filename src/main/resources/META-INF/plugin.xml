<idea-plugin>
    <id>io.github.archunitlens</id>
    <name>ArchUnit Lens</name>
    <vendor>ArchUnit Lens Contributors</vendor>
    <description><![CDATA[<p><b>ArchUnit Lens</b> shows supported ArchUnit rule violations as IntelliJ IDEA inspections while coding.</p><p>ArchUnit tests remain the source of truth; this plugin provides early IDE feedback and a rule overview tool window for a conservative subset of static Java DSL rule patterns.</p>]]></description>
    <resource-bundle>messages.ArchUnitLensBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                language="JAVA"
                shortName="ArchUnitLens"
                displayName="%inspection.display.name"
                groupName="%inspection.group.name"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="io.github.archunitlens.inspections.ArchUnitLensInspection"/>
        <toolWindow
                id="ArchUnit Lens"
                anchor="right"
                factoryClass="io.github.archunitlens.ui.ArchUnitLensToolWindowFactory"/>
        <applicationConfigurable
                id="io.github.archunitlens.settings"
                displayName="%settings.display.name"
                instance="io.github.archunitlens.settings.ArchUnitLensConfigurable"/>
    </extensions>
</idea-plugin>
